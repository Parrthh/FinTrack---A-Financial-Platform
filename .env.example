# ── Backend (backend/.env) ──────────────────────────────────────────────
# Environment name: dev | staging | prod
ENV=dev

# Postgres in production (Render), SQLite locally if unset.
# DATABASE_URL=postgresql://user:password@host:5432/fintrack
DATABASE_URL=sqlite:///./fintrack_dev.db

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-a-long-random-string

# Comma-separated allowed browser origins (the deployed frontend URL in prod).
CORS_ORIGINS=http://localhost:3000

# Cross-site cookie settings for production (frontend and API on different domains):
# REFRESH_COOKIE_SECURE=true
# REFRESH_COOKIE_SAMESITE=none

# Shared secret for /api/jobs/* endpoints (GitHub Actions cron). Empty = disabled.
# Generate like JWT_SECRET; set the same value as the FINTRACK_JOB_TOKEN repo secret.
JOB_TOKEN=

# ── Frontend (frontend/.env.local) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
